#!/usr/bin/env php
<?php

// DEV ONLY: 
require __DIR__ . '/../vendor/autoload.php';

use ApiCrumbs\Framework\EnvLoader;

// 🔥 The Spark: Boot the Environment before anything else runs
EnvLoader::load(getcwd() . '/.env');

$args = $argv;
$command = $args[1] ?? 'help';

switch ($command) {
    case 'make':
        (new \ApiCrumbs\Framework\Commands\MakeCommand())->handle($args);
        break;
    case 'suggest':
        (new \ApiCrumbs\Framework\Commands\SuggestCommand())->handle($args);
        break;
    case 'install:crumb':
        (new \ApiCrumbs\Framework\Commands\InstallCrumbCommand())->handle($args);
        break;        
    case 'install:recipe':
        (new \ApiCrumbs\Framework\Commands\InstallRecipeCommand())->handle($args);
        break;        
    case 'list:crumbs':
        (new \ApiCrumbs\Framework\Commands\ListCrumbsCommand())->handle($args);
        break;
    case 'list:recipes':
        (new \ApiCrumbs\Framework\Commands\ListRecipesCommand())->handle($args);
        break;
    case 'linter':
        (new \ApiCrumbs\Framework\Commands\LinterCommand())->handle();
        break;
    case 'update':
        (new \ApiCrumbs\Framework\Commands\UpdateCommand())->handle($argv);
        break;
    case 'logs':
        (new \ApiCrumbs\Framework\Commands\LogsCommand())->handle($args);
        break;
    case 'run':
        (new \ApiCrumbs\Framework\Commands\RunCommand())->handle($args);
        break;
    case 'doctor':
        (new \ApiCrumbs\Framework\Commands\DoctorCommand())->handle();
        break;
    case 'bench':
        (new \ApiCrumbs\Framework\Commands\BenchCommand())->handle($args);
        break;
    case 'auth:check':
        (new \ApiCrumbs\Framework\Commands\AuthCheckCommand())->handle();
        break;
    case 'setup:env':
        (new \ApiCrumbs\Framework\Commands\EnvSetupCommand())->handle();
        break;
    default:
        echo "\e[1;34m🍪 ApiCrumbs Foundry CLI\e[0m\n";
        echo "Usage: php foundry [command] [options]\n\n";
        echo "  \e[32mlist:crumbs\e[0m                          Lists all available crumbs\n";
        echo "  \e[32mlist:recipes\e[0m                         Lists all available recipes\n";
        echo "  \e[32minstall:crumb [Path]\e[0m                 Downloads a free crumb\n";
        echo "  \e[32minstall:recipe [Path]\e[0m                Downloads a free recipe\n";
        echo "  \e[32mlinter\e[0m                               Checks crumbs architectural linting\n";
        echo "  \e[32mupdate\e[0m                               Synchronises local crumbs with the remote crumbs\n";
        echo "  \e[32mdoctor\e[0m                               Ensures local crumbs area Stitch-Ready\n";
        echo "  \e[32mlogs [--clear]\e[0m                       Diagnoses the issues instantly\n";
        echo "  \e[32mauth:check\e[0m                           Pings the GitHub API and inspects the X-OAuth-Scopes header is PR-Ready.\n";
        echo "  \e[32mrun [Name] [Id] [--Json]\e[0m             Runs a single crumb and dumps its transform() output\n";
        echo "  \e[32mbench [Name] [Id]\e[0m                    Benchmark raw data size against refined markdown output\n";
        echo "  \e[32mmake [Name] [Category]\e[0m               Creates a custom crumb stub\n";
        echo "  \e[32msuggest [Name] [Category] [Reason]\e[0m   Suggests a new crumb with a name, category and reason\n";
        echo "  \e[32msetup:env\e[0m                            Generates a boilerplate .env with placeholders for PRO, CH and HMRC keys\n";
    
        break;
}